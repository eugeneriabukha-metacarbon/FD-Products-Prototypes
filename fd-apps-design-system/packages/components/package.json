    "storybook:build": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@financedistrict/apps-icons": "*",
    "@financedistrict/apps-tokens": "*",
    "@fontsource-variable/archivo": "^5.2.8",
