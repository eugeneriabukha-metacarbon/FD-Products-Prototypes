    "./accordion": "./src/accordion/index.ts",
    "./button": "./src/button/index.ts",
    "./checkbox": "./src/checkbox/index.ts",
    "./dialog": "./src/dialog/index.ts",
    "./feature-card": "./src/feature-card/index.ts",
    "./filter": "./src/filter/index.ts",
    "./inline-select": "./src/inline-select/index.ts",
    "./input": "./src/input/index.ts",
    "./panel": "./src/panel/index.ts",
    "./property-grid": "./src/property-grid/index.ts",
    "./radio": "./src/radio/index.ts",
    "./search-bar": "./src/search-bar/index.ts",
    "./select": "./src/select/index.ts",
    "./selectable-feature-card": "./src/selectable-feature-card/index.ts",
    "./switch": "./src/switch/index.ts",
    "./table-cell": "./src/table-cell/index.ts",
    "./tabs": "./src/tabs/index.ts",
    "./toast": "./src/toast/index.ts",
    "./token-input": "./src/token-input/index.ts",
    "./tooltip": "./src/tooltip/index.ts",
    "./cut-corner": "./src/lib/cut-corner.ts",
    "./scrollbar": "./src/lib/scrollbar.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
